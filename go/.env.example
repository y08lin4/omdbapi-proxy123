# 服务监听地址
LISTEN_ADDR=:8080

# OMDb 官方 key 池：一行一个 key
OMDB_KEYS_FILE=omdb_keys.txt

# 你自己发给客户端的访问 key：一行一个 key
CLIENT_KEYS_FILE=client_keys.txt

# 管理接口 key；为空时 /admin/* 禁用
ADMIN_KEY=change_me_admin_key

# 官方 OMDb 数据 API 与海报 API
OMDB_API_URL=https://www.omdbapi.com/
OMDB_POSTER_URL=https://img.omdbapi.com/

# 上游请求超时、OMDb key 失败冷却时间
HTTP_TIMEOUT=10s
KEY_COOLDOWN=5m

# 单次客户端请求最多尝试几个 OMDb key；0 表示最多尝试所有 key
MAX_ATTEMPTS_PER_REQUEST=0

# CORS；留空表示不加跨域头
CORS_ORIGIN=*
